# ─────────────────────────────────────────────
# Identity Capsule OS — Environment Variables
# Copy this file to .env.local for development
# ─────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/identity_capsule_os"

# JWT Secrets — generate strong random values in production
# openssl rand -hex 64
JWT_SECRET="change_me_to_a_64_char_random_hex_string"
JWT_REFRESH_SECRET="change_me_to_another_64_char_random_hex_string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Crypto Signing (ECDSA P-256)
# Generate: openssl ecparam -name prime256v1 -genkey -noout -out ec-private.pem
# Then:     openssl ec -in ec-private.pem -pubout -out ec-public.pem
# Then use base64 encoding for env vars:
# openssl base64 -in ec-private.pem -A
SIGNING_PRIVATE_KEY_BASE64="base64_encoded_ec_private_key_pem"
SIGNING_PUBLIC_KEY_BASE64="base64_encoded_ec_public_key_pem"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Identity Capsule OS"

# Rate Limiting (requests per window per IP)
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="30"

# Super Admin Seed (used by prisma/seed.ts only)
SEED_SUPER_ADMIN_EMAIL="admin@identitycapsule.internal"
SEED_SUPER_ADMIN_PASSWORD="ChangeMe_SuperSecure_2024!"
SEED_TENANT_NAME="HQ"
SEED_TENANT_DOMAIN="identitycapsule.internal"

# Optional: Redis for rate limiting at scale
# REDIS_URL="redis://localhost:6379"
